# ============================================
# APLICACIÓN
# ============================================
NODE_ENV=development
PORT=3000
APP_NAME="Sistema de Control de Correspondencia"
APP_URL=http://localhost:3000

# ============================================
# BASE DE DATOS (PostgreSQL)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=correspondencia_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# ============================================
# REDIS (Caché)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# JWT (Autenticación)
# ============================================
JWT_SECRET=mi-secreto-jwt-muy-seguro-cambiar-en-produccion
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# SEGURIDAD
# ============================================
CSRF_SECRET=csrf-secret-key
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug

# ============================================
# EMAIL (SMTP - Opcional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@correspondencia.gob.mx

# ============================================
# CORS (Orígenes permitidos)
# ============================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# FILE UPLOAD
# ============================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,png